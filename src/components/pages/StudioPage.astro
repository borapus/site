---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { type Lang, useTranslations } from '../../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<BaseLayout lang={lang} title={`${t('studio.title')} — ${t('site.name')}`} description={t('studio.label')}>
  <section class="page-head u-container">
    <span class="u-label" data-reveal>{t('studio.label')}</span>
    <h1 class="page-head__title" data-reveal data-reveal-delay="0.05">{t('studio.title')}</h1>
  </section>

  <section class="u-section" style="padding-top: 0;">
    <div class="u-container studio__grid">
      <div class="studio__text">
        <p class="studio__lead" data-reveal>{t('studio.lead')}</p>
        <p class="studio__body" data-reveal data-reveal-delay="0.1">{t('studio.body')}</p>
        <p class="studio__founder" data-reveal data-reveal-delay="0.15">
          <span class="u-label">{t('studio.founderLabel')}</span>
          <span class="studio__founder-name">{t('studio.founder')}</span>
        </p>
      </div>
      <div class="studio__media" data-reveal data-reveal-delay="0.1" data-parallax="0.08" aria-hidden="true"></div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-top: clamp(160px, 24vh, 320px);
    padding-bottom: clamp(48px, 8vh, 110px);
  }
  .page-head__title { font-size: var(--fs-display); margin-top: 20px; }

  .studio__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(40px, 7vw, 96px);
    align-items: start;
  }
  @media (min-width: 900px) {
    .studio__grid { grid-template-columns: 7fr 5fr; }
  }
  .studio__lead {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.5rem, 3vw, 2.6rem);
    line-height: 1.3;
    max-width: 26ch;
  }
  .studio__body {
    margin-top: clamp(24px, 4vh, 44px);
    max-width: 52ch;
    color: var(--color-muted);
    line-height: 1.9;
  }
  .studio__founder {
    display: grid;
    gap: 6px;
    margin-top: clamp(32px, 5vh, 60px);
  }
  .studio__founder-name {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
  }
  .studio__media {
    aspect-ratio: 4 / 5;
    background: radial-gradient(120% 100% at 30% 20%, #f3f1ec 0%, #e2ddd3 100%);
  }
</style>
