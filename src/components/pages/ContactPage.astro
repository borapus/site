---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { type Lang, useTranslations } from '../../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// Web3Forms access key — Vercel/.env'de PUBLIC_WEB3FORMS_KEY olarak ayarla.
// (web3forms.com'dan bora@pusnco.com ile ücretsiz alınır)
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY || '';
---

<BaseLayout lang={lang} title={`${t('contact.title')} — ${t('site.name')}`} description={t('contact.intro')}>
  <section class="page-head u-container">
    <span class="u-label" data-reveal>{t('contact.label')}</span>
    <h1 class="page-head__title" data-reveal data-reveal-delay="0.05">{t('contact.title')}</h1>
    <p class="page-head__intro" data-reveal data-reveal-delay="0.1">{t('contact.intro')}</p>
    <p class="form__status" data-form-status hidden>{t('contact.sent')}</p>
    <p class="form__status form__status--error" data-form-error hidden>{t('contact.error')}</p>
  </section>

  <section class="u-section" style="padding-top: 0;">
    <div class="u-container form-wrap">
      <form
        class="form"
        action="https://api.web3forms.com/submit"
        method="post"
        data-contact-form
        data-reveal
      >
        <input type="hidden" name="access_key" value={web3formsKey} />
        <input type="hidden" name="subject" value="PUS&CO — Website enquiry" />
        <input type="hidden" name="from_name" value="PUS&CO Website" />
        <input type="hidden" name="lang" value={lang} />
        <!-- honeypot (Web3Forms) -->
        <input
          type="checkbox"
          name="botcheck"
          class="form__hp"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        />

        <label class="form__field">
          <span class="u-label">{t('contact.name')}</span>
          <input type="text" name="name" required />
        </label>

        <label class="form__field">
          <span class="u-label">{t('contact.email')}</span>
          <input type="email" name="email" required />
        </label>

        <label class="form__field">
          <span class="u-label">{t('contact.message')}</span>
          <textarea name="message" rows="4" required></textarea>
        </label>

        <button class="form__submit" type="submit">
          <span class="ghost-btn__text" data-submit-text>{t('contact.send')}</span>
          <span class="ghost-btn__line" aria-hidden="true"></span>
        </button>
      </form>

      <aside class="contact-aside" data-reveal data-reveal-delay="0.1">
        <div class="contact-aside__block">
          <span class="u-label">{t('footer.studio')}</span>
          <p>Kadıköy, Istanbul, Türkiye</p>
        </div>
        <div class="contact-aside__block">
          <span class="u-label">{t('footer.contact')}</span>
          <p>
            <a class="footer__link" href="mailto:bora@pusnco.com">bora@pusnco.com</a><br />
            <a class="footer__link" href="tel:+905052632880">+90 505 263 28 80</a>
          </p>
        </div>
        <div class="contact-aside__block">
          <span class="u-label">{t('studio.founderLabel')}</span>
          <p>{t('studio.founder')}</p>
        </div>
      </aside>
    </div>
  </section>

  <script is:inline define:vars={{ sendingText: t('contact.sending'), sendText: t('contact.send'), hasKey: Boolean(web3formsKey) }}>
    (function () {
      var form = document.querySelector('[data-contact-form]');
      if (!form) return;
      var statusEl = document.querySelector('[data-form-status]');
      var errorEl = document.querySelector('[data-form-error]');
      var btnText = form.querySelector('[data-submit-text]');
      var btn = form.querySelector('button[type=submit]');

      function show(el) { if (el) { el.hidden = false; el.scrollIntoView({ behavior: 'smooth', block: 'center' }); } }
      function hide(el) { if (el) el.hidden = true; }

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        hide(statusEl); hide(errorEl);
        if (!hasKey) { show(errorEl); console.warn('[contact] PUBLIC_WEB3FORMS_KEY tanımlı değil — formu bağlamak için Vercel env değişkenini ekle.'); return; }
        var original = btnText ? btnText.textContent : '';
        if (btnText) btnText.textContent = sendingText;
        if (btn) btn.disabled = true;

        fetch(form.action, { method: 'POST', body: new FormData(form), headers: { Accept: 'application/json' } })
          .then(function (r) { return r.json(); })
          .then(function (json) {
            if (json && json.success) { form.reset(); show(statusEl); }
            else { show(errorEl); }
          })
          .catch(function () { show(errorEl); })
          .finally(function () {
            if (btnText) btnText.textContent = original || sendText;
            if (btn) btn.disabled = false;
          });
      });
    })();
  </script>
</BaseLayout>

<style>
  .page-head {
    padding-top: clamp(160px, 24vh, 320px);
    padding-bottom: clamp(40px, 7vh, 90px);
  }
  .page-head__title { font-size: var(--fs-display); margin-top: 20px; }
  .page-head__intro { margin-top: 24px; max-width: 40ch; color: var(--color-muted); }
  .form__status {
    margin-top: 28px;
    padding-top: 20px;
    border-top: 1px solid var(--color-line);
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.4vw, 2rem);
    color: var(--color-ink);
  }
  .form__status--error {
    font-size: clamp(1rem, 1.8vw, 1.4rem);
    color: var(--color-muted);
  }

  .form-wrap {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(48px, 8vw, 120px);
  }
  @media (min-width: 900px) {
    .form-wrap { grid-template-columns: 7fr 4fr; }
  }

  .form { display: grid; gap: clamp(28px, 4vh, 44px); }
  .form__hp { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }

  .form__field { display: grid; gap: 12px; }
  .form__field input,
  .form__field textarea {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: var(--fs-body);
    color: var(--color-ink);
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--color-line);
    padding: 10px 0;
    transition: border-color var(--dur-base) var(--ease);
    resize: vertical;
  }
  .form__field input:focus,
  .form__field textarea:focus {
    outline: none;
    border-color: var(--color-ink);
  }

  .form__submit {
    justify-self: start;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-top: 8px;
    color: var(--color-ink);
    transition: color var(--dur-base) var(--ease), transform var(--dur-base) var(--ease);
  }
  .form__submit:hover { color: var(--color-muted); transform: translateY(-2px); }
  .form__submit:hover .ghost-btn__line { width: clamp(44px, 6vw, 84px); }

  .contact-aside { display: grid; gap: clamp(28px, 4vh, 44px); align-content: start; }
  .contact-aside__block p { margin-top: 14px; color: var(--color-muted); line-height: 1.9; }
</style>
