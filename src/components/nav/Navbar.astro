---
import { type Lang, useTranslations, localizedPath, type UIKey } from '../../i18n/ui';
import LocaleSwitch from './LocaleSwitch.astro';
import MenuOverlay from './MenuOverlay.astro';
import LogoIcon from '../ui/LogoIcon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const items: { key: UIKey; href: string }[] = [
  { key: 'nav.home', href: localizedPath('/', lang) },
  { key: 'nav.projects', href: localizedPath('/projects', lang) },
  { key: 'nav.studio', href: localizedPath('/studio', lang) },
  { key: 'nav.contact', href: localizedPath('/contact', lang) },
];
---

<header class="nav">
  <div class="nav__inner u-container">
    <a class="nav__brand" href={localizedPath('/', lang)} aria-label="Pus&Co Architects">
      <LogoIcon class="nav__logo" />
      <span class="nav__wordmark">Pus&amp;Co</span>
    </a>

    <div class="nav__right">
      <LocaleSwitch lang={lang} />
      <button class="nav__menu" data-menu-toggle type="button" aria-label={t('nav.menu')}>
        <span class="ghost-underline">{t('nav.menu')}</span>
      </button>
    </div>
  </div>
</header>

<MenuOverlay lang={lang} items={items} />

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 80;
    padding-block: clamp(18px, 3vh, 34px);
    /* Varsayılan: açık (hero fotoğrafı üstünde). Scroll/iç sayfada .is-dark ile koyar. */
    --nav-fg: #f5f2ec;
  }
  .nav.is-dark { --nav-fg: var(--color-ink); }
  :global(html.menu-open) .nav { --nav-fg: var(--color-ink); } /* menü açık = beyaz zemin */

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    color: var(--nav-fg);
    transition: color var(--dur-base) var(--ease);
  }
  :global(.nav__logo) {
    height: 22px;
    width: auto;
    display: block;
  }
  .nav__wordmark {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--fs-label);
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }
  .nav__right {
    display: flex;
    align-items: center;
    gap: clamp(20px, 3vw, 44px);
  }
  .nav__menu {
    font-size: var(--fs-label);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--nav-fg);
    transition: color var(--dur-base) var(--ease);
  }

  /* Locale switch renklerini nav rengine bağla (yeterli özgüllük için .nav .nav__right) */
  .nav .nav__right :global(.locale__link),
  .nav .nav__right :global(.locale__sep) {
    color: var(--nav-fg);
    opacity: 0.68;
    transition: color var(--dur-base) var(--ease), opacity var(--dur-base) var(--ease);
  }
  .nav .nav__right :global(.locale__link:hover),
  .nav .nav__right :global(.locale__link.is-active) { color: var(--nav-fg); opacity: 1; }
</style>
