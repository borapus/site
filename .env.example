# Sanity — bu değerleri doldurunca projeler "canlı" olarak çekilir.
# sanity.io'da ücretsiz proje oluştur, dataset'i "production" (public read) yap,
# ve site origin'ini Sanity CORS ayarlarına ekle.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# İletişim formu — web3forms.com'dan ücretsiz access key (bora@pusnco.com ile).
# Vercel'de: Settings > Environment Variables > PUBLIC_WEB3FORMS_KEY
PUBLIC_WEB3FORMS_KEY=
