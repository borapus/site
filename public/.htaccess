# ==========================================================
#  ATELIER — LiteSpeed / Apache yapılandırması (turkticaret.net)
#  Bu dosya public/ içinde olduğu için build'de dist/ köküne kopyalanır.
# ==========================================================

# ---- HTTPS zorla ----
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ---- (Opsiyonel) Sunucu tarafı dil yönlendirme ----
# Kök (/) index.html zaten JS ile dil algılayıp yönlendiriyor (localStorage'ı da dikkate alır).
# JS'siz ziyaretçiler için sunucu tarafı yönlendirmeyi istersen aşağıyı aç:
#
# RewriteCond %{REQUEST_URI} ^/$
# RewriteCond %{HTTP:Accept-Language} ^tr [NC]
# RewriteRule ^$ /tr/ [L,R=302]
# RewriteCond %{REQUEST_URI} ^/$
# RewriteRule ^$ /en/ [L,R=302]

# ---- Güvenlik başlıkları ----
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ---- Statik varlık cache ----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/avif "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ---- Sıkıştırma ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# ---- Özel 404 (isteğe bağlı) ----
# ErrorDocument 404 /en/404.html
